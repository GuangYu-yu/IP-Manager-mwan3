config globals 'globals'
	option mmx_mask '0x3F00'

# ==================== 接口定义 ====================

config interface 'cmcc'
	option enabled '1'
	list track_ip '223.5.5.5'
	list track_ip '223.6.6.6'
	list track_ip '114.114.114.114'
	list track_ip '114.114.115.115'
	option family 'ipv4'
	option reliability '1'

config interface 'cmcc_6'
	option enabled '1'
	list track_ip '2400:3200::1'
	list track_ip '2400:3200:baba::1'
	option family 'ipv6'
	option reliability '1'

config interface 'cnc'
	option enabled '1'
	list track_ip '223.5.5.5'
	list track_ip '223.6.6.6'
	list track_ip '114.114.114.114'
	list track_ip '114.114.115.115'
	option family 'ipv4'
	option reliability '1'

config interface 'cnc_6'
	option enabled '1'
	list track_ip '2400:3200::1'
	list track_ip '2400:3200:baba::1'
	option family 'ipv6'
	option reliability '1'

config interface 'ct'
	option enabled '1'
	list track_ip '223.5.5.5'
	list track_ip '223.6.6.6'
	list track_ip '114.114.114.114'
	list track_ip '114.114.115.115'
	option family 'ipv4'
	option reliability '1'

config interface 'ct_6'
	option enabled '1'
	list track_ip '2400:3200::1'
	list track_ip '2400:3200:baba::1'
	option family 'ipv6'
	option reliability '1'

# ==================== 成员定义 ====================
# weight 按实际带宽比例调整，默认等权重(1:1:1)

config member 'cmcc_m1_w1'
	option interface 'cmcc'
	option metric '1'
	option weight '1'

config member 'cmcc6_m1_w1'
	option interface 'cmcc_6'
	option metric '1'
	option weight '1'

config member 'cnc_m1_w1'
	option interface 'cnc'
	option metric '1'
	option weight '1'

config member 'cnc6_m1_w1'
	option interface 'cnc_6'
	option metric '1'
	option weight '1'

config member 'ct_m1_w1'
	option interface 'ct'
	option metric '1'
	option weight '1'

config member 'ct6_m1_w1'
	option interface 'ct_6'
	option metric '1'
	option weight '1'

# ==================== 策略定义 ====================

# 三网均衡（默认策略 - 带宽叠加）
config policy 'balanced'
	list use_member 'cmcc_m1_w1'
	list use_member 'cnc_m1_w1'
	list use_member 'ct_m1_w1'
	list use_member 'cmcc6_m1_w1'
	list use_member 'cnc6_m1_w1'
	list use_member 'ct6_m1_w1'
	option last_resort 'default'

# 单运营商独立策略
config policy 'cmcc_only'
	list use_member 'cmcc_m1_w1'
	list use_member 'cmcc6_m1_w1'

config policy 'cnc_only'
	list use_member 'cnc_m1_w1'
	list use_member 'cnc6_m1_w1'

config policy 'ct_only'
	list use_member 'ct_m1_w1'
	list use_member 'ct6_m1_w1'

# ==================== 规则定义 ====================
# 规则从上到下依次匹配，命中即停止

# 1) 运营商分流: v4 匹配对应 ipset 的走该运营商出口
config rule 'isp_cmcc_v4'
	option enabled '1'
	option ipset 'cmcc4'
	option use_policy 'cmcc_only'
	option family 'ipv4'

config rule 'isp_cnc_v4'
	option enabled '1'
	option ipset 'cnc4'
	option use_policy 'cnc_only'
	option family 'ipv4'

config rule 'isp_ct_v4'
	option enabled '1'
	option ipset 'ct4'
	option use_policy 'ct_only'
	option family 'ipv4'

# 2) 运营商分流: v6 匹配对应 ipset 的走该运营商出口
config rule 'isp_cmcc_v6'
	option enabled '1'
	option ipset 'cmcc6'
	option use_policy 'cmcc_only'
	option family 'ipv6'

config rule 'isp_cnc_v6'
	option enabled '1'
	option ipset 'cnc6'
	option use_policy 'cnc_only'
	option family 'ipv6'

config rule 'isp_ct_v6'
	option enabled '1'
	option ipset 'ct6'
	option use_policy 'ct_only'
	option family 'ipv6'

# 3) Cloudflare 规则
config rule 'cf4'
	option enabled '1'
	option ipset 'cf4'
	option use_policy 'ct_only'
	option family 'ipv4'

config rule 'cf6'
	option enabled '1'
	option ipset 'cf6'
	option use_policy 'ct_only'
	option family 'ipv6'

# 4) 默认规则 - 未命中以上所有条件的走三网均衡
config rule 'default_rule_v4'
	option enabled '1'
	option sticky '1'
	option dest_ip '0.0.0.0/0'
	option use_policy 'balanced'
	option family 'ipv4'

config rule 'default_rule_v6'
	option enabled '1'
	option sticky '1'
	option dest_ip '::/0'
	option use_policy 'balanced'
	option family 'ipv6'